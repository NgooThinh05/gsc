// GSC PROCUREMENT SYSTEM - PRISMA SCHEMA
// Database: PostgreSQL
// ORM: Prisma
// Pattern: Table-per-Type (TPT) cho Subtyping

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ENUMS - ĐỊNH NGHĨA CÁC GIÁ TRỊ HẰNG

enum VaiTro {
  Admin // IT - Quản lý hệ thống, tài khoản
  NhanVienHopDong // Nhân viên quản lý hợp đồng
  NhanVienMuaSamCoQuan // Nhân viên mua sắm (từ cơ quan)
  NhanVienThanhToan // Nhân viên thanh toán / Kế toán
  NhanVienKho // Nhân viên kho / Xuất kho
  QuanLy // Quản lý / Giám sát
}

enum TrangThaiTaiKhoan {
  HoatDong // Tài khoản hoạt động
  Khoa // Tài khoản bị khóa / vô hiệu hóa
}

enum TrangThaiHopDong {
  HieuLuc // Hợp đồng còn hiệu lực
  HetHan // Hợp đồng hết hạn
  TamDung // Hợp đồng tạm dừng
}

enum TrangThaiDonHang {
  ChoDuyet // Đợi duyệt từ NV Hợp đồng
  DaDuyet // Đã duyệt, chuyển sang kiểm tra kho
  SanSangGiao // Hàng đủ, sẵn sàng giao
  GiaoMotPhan // Giao một phần (hàng thiếu)
  DaGiao // Đã giao đủ
  Huy // Đơn hàng bị hủy
}

enum TrangThaiGiaoHang {
  DangDongGoi // Đang chuẩn bị / đóng gói
  DangGiao // Đang giao hàng
  DaGiao // Giao thành công
  ThatBai // Giao hàng thất bại
}

enum TrangThaiHoaDon {
  ChoThanhToan // Chờ thanh toán
  DaThanhToan // Đã thanh toán
  QuaHan // Quá hạn thanh toán
  Huy // Hóa đơn bị hủy
}

enum TrangThaiHangHoa {
  CoDuong // Hàng hóa còn kinh doanh
  HetHang // Hết hàng
}

// BẢNG TÀI KHOẢN - SUPERTABLE

model TaiKhoan {
  MaTaiKhoan   Int               @id @default(autoincrement())
  TenNguoiDung String            @unique @db.VarChar(255)
  SDT          String?           @unique @db.VarChar(15)
  Email        String            @unique @db.VarChar(255)
  MatKhau      String            @db.VarChar(255) // Bcrypt hash
  VaiTro       VaiTro
  TrangThai    TrangThaiTaiKhoan @default(HoatDong)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  // Relations - Subtype (1-1)
  nhanVienHopDong      NhanVienHopDong?
  nhanVienMuaSamCoQuan NhanVienMuaSamCoQuan?
  nhanVienThanhToan    NhanVienThanhToan?
  nhanVienKho          NhanVienKho?

  // Relations - Nghiệp vụ
  hopDongs    HopDong[] // Hợp đồng do NV này quản lý
  donDatHangs DonDatHang[] // Đơn hàng do NV Mua sắm này tạo
  giaoHangs   GiaoHang[] // Giao hàng do NV Kho này thực hiện
  hoaDons     HoaDonThanhToan[] // Hóa đơn do NV TT này tạo
  ThuTuChoi   ThuTuChoi[]

  @@map("TaiKhoan")
}

// BẢNG SUBTYPE - NHÂN VIÊN (TABLE-PER-TYPE)

model NhanVienHopDong {
  MaTaiKhoan  Int      @id
  ChucVu      String   @db.VarChar(100)
  ChungChi    String?  @db.VarChar(255) // Chứng chỉ, bằng cấp
  HanMucDuyet Decimal? @db.Decimal(18, 2) // Hạn mức duyệt đơn hàng

  taiKhoan TaiKhoan @relation(fields: [MaTaiKhoan], references: [MaTaiKhoan], onDelete: Cascade)

  @@map("NhanVienHopDong")
}

model NhanVienMuaSamCoQuan {
  MaTaiKhoan    Int    @id
  MaCoQuan      Int // FK tới CoQuanChinhPhu
  BoPhanCongTac String @db.VarChar(100)

  taiKhoan TaiKhoan       @relation(fields: [MaTaiKhoan], references: [MaTaiKhoan], onDelete: Cascade)
  coQuan   CoQuanChinhPhu @relation(fields: [MaCoQuan], references: [MaCoQuan], onDelete: Restrict)

  @@map("NhanVienMuaSamCoQuan")
}

model NhanVienThanhToan {
  MaTaiKhoan   Int      @id
  MaSoKeToan   String   @unique @db.VarChar(50)
  HanMucChiTra Decimal? @db.Decimal(18, 2) // Hạn mức chỉ trả

  taiKhoan TaiKhoan @relation(fields: [MaTaiKhoan], references: [MaTaiKhoan], onDelete: Cascade)

  @@map("NhanVienThanhToan")
}

model NhanVienKho {
  MaTaiKhoan   Int    @id
  KhuVucQuanLy String @db.VarChar(100) // Khu vực quản lý: Chi nhánh A, Chi nhánh B, ...
  CaLam        String @db.VarChar(50) // Sáng / Chiều / Tối

  taiKhoan TaiKhoan @relation(fields: [MaTaiKhoan], references: [MaTaiKhoan], onDelete: Cascade)

  giaoHangs GiaoHang[] @relation("NhanVienKhoToGiaoHang")

  @@map("NhanVienKho")
}

// BẢNG CƠ QUAN CHÍNH PHỦ

model CoQuanChinhPhu {
  MaCoQuan  Int      @id @default(autoincrement())
  Ten       String   @db.VarChar(255)
  DiaChi    String?  @db.Text
  DienThoai String?  @db.VarChar(15)
  Email     String?  @db.VarChar(255)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  nhanVienMuaSam NhanVienMuaSamCoQuan[]
  hopDongs       HopDong[]

  @@map("CoQuanChinhPhu")
}

// BẢNG HỢP ĐỒNG & CHI TIẾT

model HopDong {
  MaHopDong       Int              @id @default(autoincrement())
  NgayKy          DateTime
  NgayHetHan      DateTime
  TrangThai       TrangThaiHopDong @default(HieuLuc)
  DieuKhoan       String?          @db.Text // Điều khoản hợp đồng
  MaTaiKhoan_NVHD Int // FK tới NhanVienHopDong (qua TaiKhoan)
  MaCoQuan        Int // FK tới CoQuanChinhPhu
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  // Relations
  nhanVienHopDong TaiKhoan         @relation(fields: [MaTaiKhoan_NVHD], references: [MaTaiKhoan], onDelete: Restrict)
  coQuan          CoQuanChinhPhu   @relation(fields: [MaCoQuan], references: [MaCoQuan], onDelete: Restrict)
  chiTiet         ChiTietHopDong[]
  donDatHangs     DonDatHang[]

  @@index([MaTaiKhoan_NVHD])
  @@index([MaCoQuan])
  @@map("HopDong")
}

model ChiTietHopDong {
  MaHopDong    Int
  MaHangHoa    Int
  SoLuongToiDa Int
  SoTienToiDa  Decimal  @db.Decimal(18, 2)
  createdAt    DateTime @default(now())

  hopDong HopDong @relation(fields: [MaHopDong], references: [MaHopDong], onDelete: Cascade)
  hangHoa HangHoa @relation(fields: [MaHangHoa], references: [MaHangHoa], onDelete: Restrict)

  @@id([MaHopDong, MaHangHoa])
  @@map("ChiTietHopDong")
}

// BẢNG ĐƠN ĐẶT HÀNG & CHI TIẾT

model DonDatHang {
  MaDonHang       Int              @id @default(autoincrement())
  NgayDat         DateTime         @default(now())
  TrangThai       TrangThaiDonHang @default(ChoDuyet)
  TongTien        Decimal          @db.Decimal(18, 2) // Tổng tiền ước tính
  LuuY            String?          @db.Text // Lưu ý / Ghi chú thêm
  MaHopDong       Int // FK tới HopDong
  MaTaiKhoan_NVMS Int // FK tới NhanVienMuaSamCoQuan (qua TaiKhoan)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  // Relations
  hopDong     HopDong           @relation(fields: [MaHopDong], references: [MaHopDong], onDelete: Restrict)
  nhanVienMua TaiKhoan          @relation(fields: [MaTaiKhoan_NVMS], references: [MaTaiKhoan], onDelete: Restrict)
  chiTiet     ChiTietDonHang[]
  giaoHangs   GiaoHang[]
  hoaDons     HoaDonThanhToan[]
  ThuTuChoi   ThuTuChoi[]

  @@index([MaHopDong])
  @@index([MaTaiKhoan_NVMS])
  @@map("DonDatHang")
}

model ChiTietDonHang {
  MaDonHang   Int
  MaHangHoa   Int
  SoLuongDat  Int
  SoLuongGiao Int      @default(0) // Số lượng thực tế được giao (có thể < SoLuongDat nếu thiếu hàng)
  DonGia      Decimal  @default(0) @db.Decimal(18, 2) // Giá tại thời điểm đặt hàng
  createdAt   DateTime @default(now())

  donHang DonDatHang @relation(fields: [MaDonHang], references: [MaDonHang], onDelete: Cascade)
  hangHoa HangHoa    @relation(fields: [MaHangHoa], references: [MaHangHoa], onDelete: Restrict)

  @@id([MaDonHang, MaHangHoa])
  @@map("ChiTietDonHang")
}

// BẢNG HÀNG HÓA

model HangHoa {
  MaHangHoa       Int              @id @default(autoincrement())
  Ten             String           @db.VarChar(255)
  Gia             Decimal          @db.Decimal(18, 2)
  SoLuongTrongKho Int              @default(0)
  ViTriKho        String?          @db.VarChar(100) // Khu vực, tầng, kệ, ...
  MoTa            String?          @db.Text
  TrangThai       TrangThaiHangHoa @default(CoDuong)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @default(now())

  // Relations
  chiTietHopDong ChiTietHopDong[]
  chiTietDonHang ChiTietDonHang[]

  @@map("HangHoa")
}

// BẢNG GIAO HÀNG

model GiaoHang {
  MaGiaoHang       Int               @id @default(autoincrement())
  NgayGiao         DateTime          @default(now())
  DonViVanChuyen   String?           @db.VarChar(100) // Công ty vận chuyển
  TrangThai        TrangThaiGiaoHang @default(DangDongGoi)
  GhiChu           String?           @db.Text
  MaDonHang        Int // FK tới DonDatHang
  MaTaiKhoan_NVKho Int // FK tới NhanVienKho (qua TaiKhoan)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  // Relations
  donHang     DonDatHang @relation(fields: [MaDonHang], references: [MaDonHang], onDelete: Restrict)
  nhanVienKho TaiKhoan   @relation("NhanVienKhoToGiaoHang", fields: [MaTaiKhoan_NVKho], references: [MaTaiKhoan], onDelete: Restrict)

  @@index([MaDonHang])
  @@index([MaTaiKhoan_NVKho])
  @@map("GiaoHang")
}

// BẢNG HÓA ĐƠN THANH TOÁN

model HoaDonThanhToan {
  MaHoaDon          Int             @id @default(autoincrement())
  NgayLap           DateTime        @default(now())
  HinhThucThanhToan String?         @db.VarChar(100) // Tiền mặt, Chuyển khoản, ...
  TongTien          Decimal         @db.Decimal(18, 2) // Tính từ SoLuongGiao * DonGia
  TrangThai         TrangThaiHoaDon @default(ChoThanhToan)
  GhiChu            String?         @db.Text
  MaDonHang         Int // FK tới DonDatHang
  MaTaiKhoan_NVTT   Int // FK tới NhanVienThanhToan (qua TaiKhoan)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  // Relations
  donHang           DonDatHang @relation(fields: [MaDonHang], references: [MaDonHang], onDelete: Restrict)
  nhanVienThanhToan TaiKhoan   @relation(fields: [MaTaiKhoan_NVTT], references: [MaTaiKhoan], onDelete: Restrict)

  @@index([MaDonHang])
  @@index([MaTaiKhoan_NVTT])
  @@map("HoaDonThanhToan")
}

// BẢNG THƯĐƠN TỪ CHỐI (OPTIONAL - Nếu cần)

model ThuTuChoi {
  MaThuTuChoi     Int      @id @default(autoincrement())
  LiDo            String   @db.Text
  NgayGui         DateTime @default(now())
  MaDonHang       Int // FK tới DonDatHang
  MaTaiKhoan_NVHD Int // FK tới NhanVienHopDong
  createdAt       DateTime @default(now())

  donHang         DonDatHang @relation(fields: [MaDonHang], references: [MaDonHang], onDelete: Cascade)
  nhanVienHopDong TaiKhoan   @relation(fields: [MaTaiKhoan_NVHD], references: [MaTaiKhoan], onDelete: Restrict)

  @@index([MaDonHang])
  @@map("ThuTuChoi")
}

// BẢNG LỊCH SỬ / AUDIT LOG (OPTIONAL)

model AuditLog {
  MaLog      Int      @id @default(autoincrement())
  HanhDong   String   @db.VarChar(255) // "CREATE_DON_HANG", "APPROVE_DON_HANG", ...
  DoiTuong   String   @db.VarChar(100) // "DonDatHang", "HoaDon", ...
  IdDoiTuong Int // ID của bản ghi liên quan
  MaTaiKhoan Int // Tài khoản thực hiện
  ChiTiet    String?  @db.Text
  createdAt  DateTime @default(now())

  @@index([IdDoiTuong])
  @@index([MaTaiKhoan])
  @@map("AuditLog")
}
