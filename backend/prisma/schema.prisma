generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model TaiKhoan {
  MaTaiKhoan      Int               @id @default(autoincrement())
  TenNguoiDung    String            @unique
  SDT             String?           @unique
  Email           String            @unique
  MatKhau         String
  VaiTro          VaiTro
  TrangThai       TrangThaiTaiKhoan @default(HoatDong)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  donDatHangs     DonDatHang[]      @relation("DonDatHang_NVMS")
  giaoHangs       GiaoHang[]
  hoaDons         HoaDonThanhToan[]
  hopDongs        HopDong[]         @relation("HopDong_NVHD")
  nhanVienHopDong NhanVienHopDong?
  nhanVienKho     NhanVienKho?
  quanLy          QuanLy?
  taiKhoanCoQuan  TaiKhoanCoQuan?
  ThuTuChoi       ThuTuChoi[]

  @@map("TaiKhoan")
}

model NhanVienHopDong {
  MaTaiKhoan Int      @id
  taiKhoan   TaiKhoan @relation(fields: [MaTaiKhoan], references: [MaTaiKhoan], onDelete: Cascade)

  @@map("NhanVienHopDong")
}

model TaiKhoanCoQuan {
  MaTaiKhoan Int            @id(map: "NhanVienMuaSamCoQuan_pkey")
  MaCoQuan   Int
  coQuan     CoQuanChinhPhu @relation(fields: [MaCoQuan], references: [MaCoQuan], map: "NhanVienMuaSamCoQuan_MaCoQuan_fkey")
  taiKhoan   TaiKhoan       @relation(fields: [MaTaiKhoan], references: [MaTaiKhoan], onDelete: Cascade, map: "NhanVienMuaSamCoQuan_MaTaiKhoan_fkey")

  @@map("TaiKhoanCoQuan")
}

model NhanVienKho {
  MaTaiKhoan Int      @id
  taiKhoan   TaiKhoan @relation(fields: [MaTaiKhoan], references: [MaTaiKhoan], onDelete: Cascade)

  @@map("NhanVienKho")
}

model QuanLy {
  MaTaiKhoan Int      @id(map: "MaTaiKhoan_Quanly")
  taiKhoan   TaiKhoan @relation(fields: [MaTaiKhoan], references: [MaTaiKhoan], onDelete: NoAction, onUpdate: NoAction, map: "Quanly")

  @@index([MaTaiKhoan], map: "AuditLog_MaTaiKhoan_idx")
  @@map("QuanLy")
}

model CoQuanChinhPhu {
  MaCoQuan       Int              @id @default(autoincrement())
  Ten            String
  DiaChi         String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @default(now())
  hopDongs       HopDong[]
  taiKhoanCoQuan TaiKhoanCoQuan[]

  @@map("CoQuanChinhPhu")
}

model HopDong {
  MaHopDong       Int              @id @default(autoincrement())
  NgayKy          DateTime
  NgayHetHan      DateTime
  TrangThai       TrangThaiHopDong @default(HieuLuc)
  DieuKhoan       String?
  MaTaiKhoan_NVHD Int
  MaCoQuan        Int
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  chiTiet         ChiTietHopDong[]
  donDatHangs     DonDatHang[]
  coQuan          CoQuanChinhPhu   @relation(fields: [MaCoQuan], references: [MaCoQuan])
  nhanVienHopDong TaiKhoan         @relation("HopDong_NVHD", fields: [MaTaiKhoan_NVHD], references: [MaTaiKhoan])

  @@index([MaTaiKhoan_NVHD])
  @@index([MaCoQuan])
  @@map("HopDong")
}

model ChiTietHopDong {
  MaHopDong   Int
  MaHangHoa   Int
  SoTienToiDa Decimal  @db.Decimal(18, 2)
  createdAt   DateTime @default(now())
  hangHoa     HangHoa  @relation(fields: [MaHangHoa], references: [MaHangHoa])
  hopDong     HopDong  @relation(fields: [MaHopDong], references: [MaHopDong], onDelete: Cascade)

  @@id([MaHopDong, MaHangHoa])
  @@map("ChiTietHopDong")
}

model DonDatHang {
  MaDonHang       Int               @id @default(autoincrement())
  NgayDat         DateTime          @default(now())
  TrangThai       TrangThaiDonHang  @default(ChoDuyet)
  TongTien        Decimal           @db.Decimal(18, 2)
  LuuY            String?
  MaHopDong       Int?
  MaTaiKhoan_NVMS Int
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  chiTiet         ChiTietDonHang[]
  hopDong         HopDong?          @relation(fields: [MaHopDong], references: [MaHopDong], onDelete: Restrict)
  nhanVienMua     TaiKhoan          @relation("DonDatHang_NVMS", fields: [MaTaiKhoan_NVMS], references: [MaTaiKhoan])
  giaoHangs       GiaoHang[]
  hoaDons         HoaDonThanhToan[]
  ThuTuChoi       ThuTuChoi[]

  @@index([MaHopDong])
  @@index([MaTaiKhoan_NVMS])
  @@map("DonDatHang")
}

model ChiTietDonHang {
  MaDonHang   Int
  MaHangHoa   Int
  SoLuongDat  Int
  SoLuongGiao Int        @default(0)
  DonGia      Decimal    @default(0) @db.Decimal(18, 2)
  createdAt   DateTime   @default(now())
  donHang     DonDatHang @relation(fields: [MaDonHang], references: [MaDonHang], onDelete: Cascade)
  hangHoa     HangHoa    @relation(fields: [MaHangHoa], references: [MaHangHoa])

  @@id([MaDonHang, MaHangHoa])
  @@map("ChiTietDonHang")
}

model HangHoa {
  MaHangHoa       Int              @id @default(autoincrement())
  Ten             String
  Gia             Decimal          @db.Decimal(18, 2)
  SoLuongTrongKho Int              @default(0)
  ViTriKho        String?
  MoTa            String?
  TrangThai       TrangThaiHangHoa @default(CoDuong)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @default(now())
  chiTietDonHang  ChiTietDonHang[]
  chiTietHopDong  ChiTietHopDong[]

  @@map("HangHoa")
}

model GiaoHang {
  MaGiaoHang       Int               @id @default(autoincrement())
  NgayGiao         DateTime          @default(now())
  DonViVanChuyen   String?
  TrangThai        TrangThaiGiaoHang @default(DangDongGoi)
  GhiChu           String?
  MaDonHang        Int
  MaTaiKhoan_NVKho Int
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  donHang          DonDatHang        @relation(fields: [MaDonHang], references: [MaDonHang])
  nhanVienKho      TaiKhoan          @relation(fields: [MaTaiKhoan_NVKho], references: [MaTaiKhoan])

  @@index([MaDonHang])
  @@index([MaTaiKhoan_NVKho])
  @@map("GiaoHang")
}

model HoaDonThanhToan {
  MaHoaDon          Int             @id @default(autoincrement())
  NgayLap           DateTime        @default(now())
  TongTien          Decimal         @db.Decimal(18, 2)
  TrangThai         TrangThaiHoaDon @default(ChoThanhToan)
  GhiChu            String?
  MaDonHang         Int
  MaTaiKhoan_NVTT   Int
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  donHang           DonDatHang      @relation(fields: [MaDonHang], references: [MaDonHang])
  nhanVienThanhToan TaiKhoan        @relation(fields: [MaTaiKhoan_NVTT], references: [MaTaiKhoan])

  @@index([MaDonHang])
  @@index([MaTaiKhoan_NVTT])
  @@map("HoaDonThanhToan")
}

model ThuTuChoi {
  MaThuTuChoi     Int        @id @default(autoincrement())
  LiDo            String
  NgayGui         DateTime   @default(now())
  MaDonHang       Int
  MaTaiKhoan_NVHD Int
  createdAt       DateTime   @default(now())
  donHang         DonDatHang @relation(fields: [MaDonHang], references: [MaDonHang], onDelete: Cascade)
  nhanVienHopDong TaiKhoan   @relation(fields: [MaTaiKhoan_NVHD], references: [MaTaiKhoan])

  @@index([MaDonHang])
  @@map("ThuTuChoi")
}

enum VaiTro {
  Admin
  NhanVienHopDong
  TaiKhoanCoQuan    @map("NhanVienMuaSamCoQuan")
  NhanVienThanhToan
  NhanVienKho
  QuanLy
}

enum TrangThaiTaiKhoan {
  HoatDong
  Khoa
}

enum TrangThaiHopDong {
  HieuLuc
  HetHan
  TamDung
}

enum TrangThaiDonHang {
  ChoDuyet
  DaDuyet
  SanSangGiao
  GiaoMotPhan
  DaGiao
  Huy
}

enum TrangThaiGiaoHang {
  DangDongGoi
  DangGiao
  DaGiao
  ThatBai
}

enum TrangThaiHoaDon {
  ChoThanhToan
  DaThanhToan
  QuaHan
  Huy
}

enum TrangThaiHangHoa {
  CoDuong
  HetHang
}
